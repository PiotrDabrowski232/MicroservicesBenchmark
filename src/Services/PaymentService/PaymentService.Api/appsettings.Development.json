{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=PaymentDb;Uid=root;Pwd=rootpassword;",
    "RabbitMq": "amqp://guest:guest@localhost:5672",
    "Kafka": "kafka:9092"
  },
  "Communication": {
    "Mode": "Async", // sync / async
    "AsyncProvider": "RabbitMQ", // RabbitMQ / kafka
    "Messaging": {
      "Routes": [
        {
          "MessageType": "ProcessPaymentMessage",
          "Publisher": false,
          "Exchange": "orders-exchange",
          "Queue": "payment-queue",
          "RoutingKey": "payment.process",
          "Topic": "payment.process",
          "ConsumerGroup": "payment-group"
        },
        {
          "MessageType": "PaymentProcessedMessage",
          "Publisher": true,
          "Exchange": "responses-exchange",
          "RoutingKey": "order.payment.processed",
          "Topic": "order.payment.processed"
        },
        {
          "MessageType": "PaymentFailedMessage",
          "Publisher": true,
          "Exchange": "responses-exchange",
          "RoutingKey": "order.payment.failed",
          "Topic": "order.payment.failed"
        }
      ]
    }
  }
}
