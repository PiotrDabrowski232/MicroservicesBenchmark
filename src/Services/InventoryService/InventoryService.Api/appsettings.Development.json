{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=InventoryDb;Uid=root;Pwd=rootpassword;"
  },
  "Communication": {
    "Mode": "Sync", // sync / async
    "SyncProvider": "Grpc", // grcp / rest
    "AsyncProvider": "RabbitMQ", // RabbitMQ / kafka
    "Messaging": {
      "RabbitMq": {
        "ConnectionString": "amqp://guest:guest@rabbitmq:5672",
        "Exchange": "orders-exchange",
        "ResponseExchange": "responses-exchange"
      },
      "Kafka": {
        "BootstrapServers": "kafka:9092"
      },
      "Routes": [
        {
          "MessageType": "ReserveProductMessage",
          "Publisher": false,
          "Queue": "inventory-queue",
          "RoutingKey": "inventory.reserve",
          "Topic": "inventory.reserve",
          "ConsumerGroup": "inventory-group"
        },
        {
          "MessageType": "OrderResponseMessage",
          "Publisher": true,
          "RoutingKey": "order.response",
          "Topic": "order.responses"
        }
      ]
    }
  }
 }
