{
  "title": "Broker Metrics",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "RabbitMQ — Queue Depth (messages ready)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (queue) (rabbitmq_queue_messages_ready{job=\"rabbitmq\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "RabbitMQ — Message Rate (publish / deliver)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(rabbitmq_channel_messages_published_total{job=\"rabbitmq\"}[$__rate_interval]))",
          "legendFormat": "Published/s"
        },
        {
          "expr": "sum(rate(rabbitmq_channel_messages_delivered_total{job=\"rabbitmq\"}[$__rate_interval]))",
          "legendFormat": "Delivered/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "LavinMQ — Queue Depth (messages ready)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "lavinmq_queue_messages_ready",
          "legendFormat": "Ready"
        },
        {
          "expr": "lavinmq_queue_messages_unacked",
          "legendFormat": "Unacked"
        }
      ]
    },
    {
      "id": 4,
      "title": "LavinMQ — Message Rate (deliver / acknowledge)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(lavinmq_global_messages_delivered_total[$__rate_interval])",
          "legendFormat": "Delivered/s"
        },
        {
          "expr": "rate(lavinmq_global_messages_acknowledged_total[$__rate_interval])",
          "legendFormat": "Acknowledged/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka — Consumer Group Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag{topic!=\"__consumer_offsets\"})",
          "legendFormat": "{{consumergroup}} / {{topic}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Kafka — Topic Partition Offset Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset{topic!=\"__consumer_offsets\"}[$__rate_interval]))",
          "legendFormat": "{{topic}}"
        }
      ]
    }
  ]
}
